---
# RCARS Prod environment variables
# Copy to prod.yml and fill in secrets:
#   cp prod.yml.example prod.yml

env: prod
target_namespace: rcars-prod
git_ref: production

# Cluster domain — get with: oc get ingresses.config.openshift.io cluster -o jsonpath='{.spec.domain}'
cluster_domain: apps.your-cluster.example.com

# Kubeconfig for the target cluster.
# After running --tags mgmt-rbac with your personal kubeconfig, switch to:
#   kubeconfig: ~/secrets/rcars-mgmt.kubeconfig
kubeconfig: ~/secrets/rcars-mgmt.kubeconfig

frontend_host: "rcars.{{ cluster_domain }}"

pg_password: CHANGEME

babylon_kubeconfig_path: ~/.kube/babylon-readonly

vertex_enabled: true
vertex_credentials_path: ~/devel/secrets/gcp-vertex-key.json

oauth_client_secret: CHANGEME
oauth_cookie_secret: CHANGEME

curator_emails:
  - your-email@redhat.com

admin_emails:
  - your-email@redhat.com

# GitHub repo for BuildConfig (public — no source secret needed)
github_repo: rhpds/rcars
