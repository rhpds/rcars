---
# RCARS Dev environment variables
# Copy to dev.yml and fill in secrets:
#   cp dev.yml.example dev.yml

env: dev
target_namespace: rcars-dev
git_ref: main

# Cluster domain — get with: oc get ingresses.config.openshift.io cluster -o jsonpath='{.spec.domain}'
cluster_domain: apps.your-cluster.example.com

# Kubeconfig for the target cluster.
# After running --tags mgmt-rbac with your personal kubeconfig, switch to:
#   kubeconfig: ~/secrets/rcars-mgmt.kubeconfig
kubeconfig: ~/secrets/rcars-mgmt.kubeconfig

# Hostname for the route
frontend_host: "rcars-dev.{{ cluster_domain }}"

# PostgreSQL password (generate with: openssl rand -hex 16)
pg_password: CHANGEME

# Read-only kubeconfig for Babylon cluster
# Path to the file on your local machine — contents will be loaded into a Secret
babylon_kubeconfig_path: ~/.kube/babylon-readonly

# Vertex AI credentials
vertex_enabled: true
vertex_credentials_path: ~/devel/secrets/gcp-vertex-key.json

# OAuth proxy secrets (generate with: openssl rand -hex 16)
oauth_client_secret: CHANGEME
oauth_cookie_secret: CHANGEME

# Curator and admin email lists
curator_emails:
  - your-email@redhat.com

admin_emails:
  - your-email@redhat.com

# ServiceAccount allowlist for cross-namespace API access (e.g. Publishing House)
sa_allowlist:
  - "system:serviceaccount:your-namespace:your-service-account"

# GitHub repo for BuildConfig (public — no source secret needed)
github_repo: rhpds/rcars
