{# RCARS v2 app manifests — three deployments (frontend, API, worker) + OAuth proxy. #}
---
# API Service (internal — used by frontend nginx proxy and cluster consumers)
apiVersion: v1
kind: Service
metadata:
  name: {{ app_name }}-api
  labels:
    app: {{ app_name }}
    component: api
spec:
  selector:
    app: {{ app_name }}
    component: api
  ports:
    - port: {{ app_port }}
      targetPort: {{ app_port }}
  type: ClusterIP
---
# Frontend Service (used by OAuth proxy)
apiVersion: v1
kind: Service
metadata:
  name: {{ app_name }}-frontend-service
  labels:
    app: {{ app_name }}
    component: frontend
spec:
  selector:
    app: {{ app_name }}
    component: frontend
  ports:
    - port: {{ app_port }}
      targetPort: {{ app_port }}
  type: ClusterIP
---
# ── API Deployment ──
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}-api
  labels:
    app: {{ app_name }}
    component: api
  annotations:
    image.openshift.io/triggers: >-
      [{"from":{"kind":"ImageStreamTag","name":"{{ app_name }}-api:latest","namespace":"{{ target_namespace }}"},"fieldPath":"spec.template.spec.containers[?(@.name==\"{{ app_name }}-api\")].image"}]
spec:
  replicas: {{ api_replicas }}
  selector:
    matchLabels:
      app: {{ app_name }}
      component: api
  template:
    metadata:
      labels:
        app: {{ app_name }}
        component: api
    spec:
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: {{ app_name }}-api
          image: "image-registry.openshift-image-registry.svc:5000/{{ target_namespace }}/{{ app_name }}-api:latest"
          imagePullPolicy: Always
          ports:
            - containerPort: {{ app_port }}
          env:
            - name: PG_USER
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_USER
            - name: PG_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_PASSWORD
            - name: PG_DB
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_DATABASE
            - name: RCARS_DATABASE_URL
              value: "postgresql://$(PG_USER):$(PG_PASSWORD)@{{ app_name }}-postgresql:{{ pg_port }}/$(PG_DB)"
            - name: RCARS_REDIS_URL
              value: "redis://{{ app_name }}-redis:6379"
{% if babylon_kubeconfig_content is defined %}
            - name: RCARS_KUBECONFIG_PATH
              value: /etc/rcars/kubeconfig
{% endif %}
{% if vertex_enabled | default(false) %}
            - name: ANTHROPIC_VERTEX_PROJECT_ID
              value: "{{ lookup('file', vertex_credentials_path | expanduser) | from_json | json_query('project_id') }}"
            - name: CLOUD_ML_REGION
              value: "{{ vertex_region }}"
            - name: GOOGLE_APPLICATION_CREDENTIALS
              value: /etc/rcars/vertex-credentials.json
{% endif %}
            - name: RCARS_CURATOR_EMAILS_STR
              value: "{{ curator_emails | join(',') }}"
            - name: RCARS_ADMIN_EMAILS_STR
              value: "{{ admin_emails | join(',') }}"
            - name: RCARS_STALE_DAYS
              value: "{{ stale_days }}"
            - name: RCARS_SA_ALLOWLIST_STR
              value: "{{ sa_allowlist | default([]) | join(',') }}"
            - name: RCARS_DEV_USER
              value: ""
            - name: HF_HOME
              value: /opt/app-root/hf_cache
          volumeMounts:
{% if babylon_kubeconfig_content is defined %}
            - name: babylon-kubeconfig
              mountPath: /etc/rcars/kubeconfig
              subPath: kubeconfig
              readOnly: true
{% endif %}
{% if vertex_enabled | default(false) %}
            - name: vertex-credentials
              mountPath: /etc/rcars/vertex-credentials.json
              subPath: credentials.json
              readOnly: true
{% endif %}
            - name: clone-workspace
              mountPath: /tmp/rcars-clones
          livenessProbe:
            httpGet:
              path: /api/v1/health
              port: {{ app_port }}
            initialDelaySeconds: 15
            periodSeconds: 30
            timeoutSeconds: 10
          readinessProbe:
            httpGet:
              path: /api/v1/health/ready
              port: {{ app_port }}
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
          resources:
            requests:
              cpu: {{ api_cpu_request }}
              memory: {{ api_memory_request }}
            limits:
              cpu: "{{ api_cpu_limit }}"
              memory: {{ api_memory_limit }}
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
      volumes:
{% if babylon_kubeconfig_content is defined %}
        - name: babylon-kubeconfig
          secret:
            secretName: {{ app_name }}-babylon-kubeconfig
{% endif %}
{% if vertex_enabled | default(false) %}
        - name: vertex-credentials
          secret:
            secretName: {{ app_name }}-vertex-credentials
{% endif %}
        - name: clone-workspace
          emptyDir:
            sizeLimit: 10Gi
---
# ── Scan Worker Deployment (analysis, catalog refresh, stale checks) ──
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}-scan-worker
  labels:
    app: {{ app_name }}
    component: scan-worker
  annotations:
    image.openshift.io/triggers: >-
      [{"from":{"kind":"ImageStreamTag","name":"{{ app_name }}-api:latest","namespace":"{{ target_namespace }}"},"fieldPath":"spec.template.spec.containers[?(@.name==\"{{ app_name }}-scan-worker\")].image"}]
spec:
  replicas: {{ scan_worker_replicas }}
  selector:
    matchLabels:
      app: {{ app_name }}
      component: scan-worker
  template:
    metadata:
      labels:
        app: {{ app_name }}
        component: scan-worker
    spec:
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: {{ app_name }}-scan-worker
          image: "image-registry.openshift-image-registry.svc:5000/{{ target_namespace }}/{{ app_name }}-api:latest"
          imagePullPolicy: Always
          command: ["arq", "rcars.workers.WorkerSettings"]
          env:
            - name: PG_USER
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_USER
            - name: PG_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_PASSWORD
            - name: PG_DB
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_DATABASE
            - name: RCARS_DATABASE_URL
              value: "postgresql://$(PG_USER):$(PG_PASSWORD)@{{ app_name }}-postgresql:{{ pg_port }}/$(PG_DB)"
            - name: RCARS_REDIS_URL
              value: "redis://{{ app_name }}-redis:6379"
{% if babylon_kubeconfig_content is defined %}
            - name: RCARS_KUBECONFIG_PATH
              value: /etc/rcars/kubeconfig
{% endif %}
{% if vertex_enabled | default(false) %}
            - name: ANTHROPIC_VERTEX_PROJECT_ID
              value: "{{ lookup('file', vertex_credentials_path | expanduser) | from_json | json_query('project_id') }}"
            - name: CLOUD_ML_REGION
              value: "{{ vertex_region }}"
            - name: GOOGLE_APPLICATION_CREDENTIALS
              value: /etc/rcars/vertex-credentials.json
{% endif %}
            - name: RCARS_CLONE_DIR
              value: /tmp/rcars-clones
            - name: RCARS_PIPELINE_ENABLED
              value: "{{ pipeline_enabled | default('true') }}"
            - name: RCARS_PIPELINE_HOUR
              value: "{{ pipeline_hour | default('4') }}"
            - name: RCARS_PIPELINE_MINUTE
              value: "{{ pipeline_minute | default('0') }}"
            - name: HF_HOME
              value: /opt/app-root/hf_cache
          volumeMounts:
{% if babylon_kubeconfig_content is defined %}
            - name: babylon-kubeconfig
              mountPath: /etc/rcars/kubeconfig
              subPath: kubeconfig
              readOnly: true
{% endif %}
{% if vertex_enabled | default(false) %}
            - name: vertex-credentials
              mountPath: /etc/rcars/vertex-credentials.json
              subPath: credentials.json
              readOnly: true
{% endif %}
            - name: clone-workspace
              mountPath: /tmp/rcars-clones
          resources:
            requests:
              cpu: {{ worker_cpu_request }}
              memory: {{ worker_memory_request }}
            limits:
              cpu: "{{ worker_cpu_limit }}"
              memory: {{ worker_memory_limit }}
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
      volumes:
{% if babylon_kubeconfig_content is defined %}
        - name: babylon-kubeconfig
          secret:
            secretName: {{ app_name }}-babylon-kubeconfig
{% endif %}
{% if vertex_enabled | default(false) %}
        - name: vertex-credentials
          secret:
            secretName: {{ app_name }}-vertex-credentials
{% endif %}
        - name: clone-workspace
          emptyDir:
            sizeLimit: 10Gi
---
# ── Recommend Worker Deployment (advisor queries, separate from scan to avoid starvation) ──
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}-recommend-worker
  labels:
    app: {{ app_name }}
    component: recommend-worker
  annotations:
    image.openshift.io/triggers: >-
      [{"from":{"kind":"ImageStreamTag","name":"{{ app_name }}-api:latest","namespace":"{{ target_namespace }}"},"fieldPath":"spec.template.spec.containers[?(@.name==\"{{ app_name }}-recommend-worker\")].image"}]
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ app_name }}
      component: recommend-worker
  template:
    metadata:
      labels:
        app: {{ app_name }}
        component: recommend-worker
    spec:
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: {{ app_name }}-recommend-worker
          image: "image-registry.openshift-image-registry.svc:5000/{{ target_namespace }}/{{ app_name }}-api:latest"
          imagePullPolicy: Always
          command: ["arq", "rcars.workers.RecommendWorkerSettings"]
          env:
            - name: PG_USER
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_USER
            - name: PG_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_PASSWORD
            - name: PG_DB
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-postgresql
                  key: POSTGRESQL_DATABASE
            - name: RCARS_DATABASE_URL
              value: "postgresql://$(PG_USER):$(PG_PASSWORD)@{{ app_name }}-postgresql:{{ pg_port }}/$(PG_DB)"
            - name: RCARS_REDIS_URL
              value: "redis://{{ app_name }}-redis:6379"
{% if vertex_enabled | default(false) %}
            - name: ANTHROPIC_VERTEX_PROJECT_ID
              value: "{{ lookup('file', vertex_credentials_path | expanduser) | from_json | json_query('project_id') }}"
            - name: CLOUD_ML_REGION
              value: "{{ vertex_region }}"
            - name: GOOGLE_APPLICATION_CREDENTIALS
              value: /etc/rcars/vertex-credentials.json
{% endif %}
            - name: HF_HOME
              value: /opt/app-root/hf_cache
{% if vertex_enabled | default(false) %}
          volumeMounts:
            - name: vertex-credentials
              mountPath: /etc/rcars/vertex-credentials.json
              subPath: credentials.json
              readOnly: true
{% endif %}
          resources:
            requests:
              cpu: {{ recommend_worker_cpu_request }}
              memory: {{ recommend_worker_memory_request }}
            limits:
              cpu: "{{ recommend_worker_cpu_limit }}"
              memory: {{ recommend_worker_memory_limit }}
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
{% if vertex_enabled | default(false) %}
      volumes:
        - name: vertex-credentials
          secret:
            secretName: {{ app_name }}-vertex-credentials
{% endif %}
---
# ── Frontend Deployment ──
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}-frontend
  labels:
    app: {{ app_name }}
    component: frontend
  annotations:
    image.openshift.io/triggers: >-
      [{"from":{"kind":"ImageStreamTag","name":"{{ app_name }}-frontend:latest","namespace":"{{ target_namespace }}"},"fieldPath":"spec.template.spec.containers[?(@.name==\"{{ app_name }}-frontend\")].image"}]
spec:
  replicas: {{ frontend_replicas }}
  selector:
    matchLabels:
      app: {{ app_name }}
      component: frontend
  template:
    metadata:
      labels:
        app: {{ app_name }}
        component: frontend
    spec:
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: {{ app_name }}-frontend
          image: "image-registry.openshift-image-registry.svc:5000/{{ target_namespace }}/{{ app_name }}-frontend:latest"
          imagePullPolicy: Always
          ports:
            - containerPort: {{ app_port }}
          livenessProbe:
            httpGet:
              path: /
              port: {{ app_port }}
            initialDelaySeconds: 5
            periodSeconds: 30
          readinessProbe:
            httpGet:
              path: /
              port: {{ app_port }}
            initialDelaySeconds: 3
            periodSeconds: 10
          resources:
            requests:
              cpu: {{ frontend_cpu_request }}
              memory: {{ frontend_memory_request }}
            limits:
              cpu: {{ frontend_cpu_limit }}
              memory: {{ frontend_memory_limit }}
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
---
# ── OAuth Proxy (fronts the frontend service) ──
apiVersion: v1
kind: Service
metadata:
  name: {{ app_name }}-oauth-proxy-service
  labels:
    app: {{ app_name }}
    component: oauth-proxy
spec:
  selector:
    app: {{ app_name }}
    component: oauth-proxy
  ports:
    - name: http
      port: 8080
      targetPort: 8080
  type: ClusterIP
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}-oauth-proxy
  labels:
    app: {{ app_name }}
    component: oauth-proxy
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ app_name }}
      component: oauth-proxy
  template:
    metadata:
      labels:
        app: {{ app_name }}
        component: oauth-proxy
    spec:
      securityContext:
        runAsNonRoot: true
        seccompProfile:
          type: RuntimeDefault
      serviceAccountName: {{ app_name }}-oauth
      containers:
        - name: oauth-proxy
          image: {{ oauth_proxy_image }}
          args:
            - -provider=openshift
            - -http-address=:8080
            - -https-address=
            - -email-domain=*
            - "-upstream=http://{{ app_name }}-frontend-service:{{ app_port }}/"
            - -client-id=$(OAUTH_CLIENT_ID)
            - -client-secret-file=/etc/proxy/secrets/client-secret
            - -cookie-secret-file=/etc/proxy/secrets/session_secret
            - "-openshift-service-account={{ app_name }}-oauth"
            - -openshift-ca=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt
            - "-skip-auth-regex=^/assets/"
            - -upstream-timeout=180s
            - -pass-user-headers=true
          env:
            - name: OAUTH_CLIENT_ID
              valueFrom:
                secretKeyRef:
                  name: {{ app_name }}-oauth-proxy-secret
                  key: client-id
          ports:
            - containerPort: 8080
              name: http
          livenessProbe:
            httpGet:
              path: /oauth/healthz
              port: 8080
            initialDelaySeconds: 10
            periodSeconds: 10
          readinessProbe:
            httpGet:
              path: /oauth/healthz
              port: 8080
            initialDelaySeconds: 5
            periodSeconds: 5
          resources:
            limits:
              cpu: 200m
              memory: 128Mi
            requests:
              cpu: 100m
              memory: 64Mi
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
          volumeMounts:
            - mountPath: /etc/proxy/secrets
              name: oauth-proxy-secret
              readOnly: true
      volumes:
        - name: oauth-proxy-secret
          secret:
            secretName: {{ app_name }}-oauth-proxy-secret
---
# Route (points to OAuth proxy → frontend → nginx proxies /api/* to API service)
apiVersion: route.openshift.io/v1
kind: Route
metadata:
  name: {{ app_name }}
  labels:
    app: {{ app_name }}
  annotations:
    haproxy.router.openshift.io/timeout: 180s
spec:
  host: "{{ frontend_host }}"
  to:
    kind: Service
    name: {{ app_name }}-oauth-proxy-service
  port:
    targetPort: http
  tls:
    termination: edge
    insecureEdgeTerminationPolicy: Redirect
